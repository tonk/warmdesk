# WarmDesk configuration file
# Environment variables override any value set here.

# HTTP port the server listens on
port: "8080"

# Database driver: sqlite | mysql | postgres
db_driver: sqlite

# SQLite (default) — path to the database file
db_dsn: "./warmdesk.db"

# PostgreSQL example:
# db_driver: postgres
# db_dsn: "host=localhost user=warmdesk password=secret dbname=warmdesk port=5432 sslmode=disable"

# MySQL / MariaDB example:
# db_driver: mysql
# db_dsn: "warmdesk:secret@tcp(localhost:3306)/warmdesk?charset=utf8mb4&parseTime=True&loc=Local"

# SMTP email settings (used for notifications: mentions, DMs, card assignments).
# These values are used as initial defaults; they can be overridden via the admin
# panel (Admin → Settings → Email) without requiring a server restart.
# Leave smtp.host empty to disable outbound email entirely.
smtp:
  host: ""             # e.g. mail.example.com or smtp.gmail.com
  port: 587            # 587 for STARTTLS (recommended), 465 for SSL, 25 for plaintext
  from: ""             # e.g. warmdesk@example.com
  username: ""         # SMTP login (often the same as the from address)
  password: ""         # SMTP password or app-specific password

# Secret used to sign JWT tokens — change this to a long random string in production
jwt_secret: "change-me-for-production"

# Comma-separated list of allowed CORS origins, or * for any
allowed_origins: "http://localhost:8080"

# Path to the built frontend files (dist/web after running `make build`)
# Leave empty during development (Vite dev server is used instead)
web_dir: "dist/web"

# Redis URL for horizontal scaling (optional).
# When set, WebSocket broadcasts are routed through Redis pub/sub so all
# server instances deliver the message to their connected clients.
# Omit or leave empty for single-instance deployments (no Redis needed).
# redis_url: "redis://localhost:6379/0"

# Default UI language for new users (en | nl | de | fr | es). Defaults to "en".
# Can be overridden per-user in their profile settings.
# default_locale: "en"

# Gin framework mode: debug | release. Defaults to "debug".
# Set to "release" in production to suppress verbose request logging.
# Can also be set via the GIN_MODE environment variable.
# gin_mode: "release"

# Database query logging level: silent | error | warn | info. Defaults to "info".
# Set to "silent" or "error" in production to suppress per-query log output.
# Can also be set via the DB_LOG environment variable.
# db_log: "silent"

# Log incoming HTTP requests. Defaults to true.
# Set to false to suppress per-request log lines (e.g. in production behind a reverse proxy).
# Can also be set via the API_LOG environment variable (API_LOG=false to disable).
# api_log: false
