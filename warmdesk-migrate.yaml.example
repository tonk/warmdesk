# warmdesk-migrate.yaml — configuration for warmdesk-export and warmdesk-import
#
# Sensitive values (passwords, tokens) can be provided as environment variables
# instead of storing them in this file:
#   WARMDESK_URL, WARMDESK_USERNAME, WARMDESK_PASSWORD, WARMDESK_PROJECT
#   PLATFORM_API_TOKEN, PLATFORM_API_KEY
#
# Any field that is still empty after the file and env vars are read will be
# prompted for interactively.

# ── WarmDesk connection ────────────────────────────────────────────────────────

warmdesk:
  url: https://warmdesk.example.com
  username: admin
  password: ""               # or set WARMDESK_PASSWORD
  project: my-project-slug   # project slug (visible in the URL)

# ── Target / source platform ──────────────────────────────────────────────────

platform:
  name: jira   # jira | trello | openproject | ryver

  # ── Jira Cloud / Jira Server ────────────────────────────────────────────────
  # Generate an API token at https://id.atlassian.com/manage-profile/security
  url: https://mycompany.atlassian.net
  email: user@example.com
  api_token: ""              # or set PLATFORM_API_TOKEN
  project_key: MYPROJ        # Jira project key (e.g. "DEV", "OPS")
  issue_type: Task           # Issue type for cards (default: Task)

  # ── Trello ──────────────────────────────────────────────────────────────────
  # Get your API key from https://trello.com/app-key
  # api_key: ""              # or set PLATFORM_API_KEY
  # token: ""                # generate at https://trello.com/1/authorize?...
  # board_id: ""             # Trello board ID (24-char hex in the board URL)

  # ── OpenProject ─────────────────────────────────────────────────────────────
  # Generate an API key under My Account → Access Tokens in OpenProject
  # url: https://openproject.example.com
  # api_token: ""            # or set PLATFORM_API_TOKEN
  # project_id: my-project   # OpenProject project identifier (slug)

  # ── Ryver ───────────────────────────────────────────────────────────────────
  # org: mycompany           # your Ryver subdomain (mycompany.ryver.com)
  # api_token: ""            # Ryver API token from the admin console
  # team: My Team            # Ryver team/workroom name to import from / export to

# ── Column mapping ─────────────────────────────────────────────────────────────
#
# Maps WarmDesk column names (left) to the corresponding status / list name on
# the target platform (right).
#
# For export: WarmDesk column → platform status/list
# For import: platform status/list → WarmDesk column (mapping is reversed)
#
# Columns not listed here are created using their WarmDesk name as-is.

column_map:
  Backlog: "To Do"
  "In Progress": "In Progress"
  "Test & Review": "In Review"
  "To Production": Done
